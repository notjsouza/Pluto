# -------------------------------------------------------
# Frontend (Next.js) — browser-accessible variables
# These are populated from amplify_outputs.json after running:
#   npm run amplify:dev
# -------------------------------------------------------
NEXT_PUBLIC_OAUTH_HANDLER_URL=https://<your-oauth-lambda>.lambda-url.us-west-1.on.aws/
NEXT_PUBLIC_PLAID_HANDLER_URL=https://<your-plaid-lambda>.lambda-url.us-west-1.on.aws/
NEXT_PUBLIC_AI_HANDLER_URL=https://<your-ai-lambda>.lambda-url.us-west-1.on.aws/
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_PLAID_ENV=sandbox

# -------------------------------------------------------
# Google OAuth — injected into the oauth Lambda at deploy time
# Get these from: https://console.cloud.google.com/ → APIs & Services → Credentials
# -------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------------------------------------------------------
# Plaid — injected into the plaid Lambda at deploy time
# Get these from: https://dashboard.plaid.com/ → Team Settings → Keys
# -------------------------------------------------------
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# -------------------------------------------------------
# OpenAI — injected into the ai Lambda at deploy time
# Get this from: https://platform.openai.com/api-keys
# -------------------------------------------------------
OPENAI_API_KEY=
